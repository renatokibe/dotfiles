# Set output colors
export GREP_COLORS="mt=4;33"
export CLICOLOR=1
export LSCOLORS=ExFxBxDxCxegedabagacad

# Set default text editor
export EDITOR='nvim'

# Increase elastic search memory pool
export ES_MIN_MEM=1024m
export ES_MAX_MEM=2048m

# Explicitly setting locale cause sometimes osx doesn't
export LC_ALL=en_US.UTF-8

# RUBY PERFS
export RUBY_GC_HEAP_INIT_SLOTS=800000
export RUBY_HEAP_FREE_MIN=100000
export RUBY_HEAP_SLOTS_INCREMENT=300000
export RUBY_HEAP_SLOTS_GROWTH_FACTOR=1
export RUBY_GC_MALLOC_LIMIT=79000000

# Project DIR
export PROJECT_DIR="$HOME/Projects"

# cpan
export PATH="$HOME/perl5/bin${PATH:+:${PATH}}"
export PERL5LIB="$HOME/perl5/lib/perl5${PERL5LIB:+:${PERL5LIB}}"
export PERL_LOCAL_LIB_ROOT="$HOME/perl5${PERL_LOCAL_LIB_ROOT:+:${PERL_LOCAL_LIB_ROOT}}"
export PERL_MB_OPT="--install_base \"$HOME/perl5\""
export PERL_MM_OPT="INSTALL_BASE=$HOME/perl5"

# brew
HOMEBREW_NO_AUTO_UPDATE=1

# Dotfiles configuration
export DOTFILES_DIR="${DOTFILES_DIR:-${HOME}/Projects/me/dotfiles}"

# Tmux auto-start session name
export TMUX_AUTOSTART_SESSION="${TMUX_AUTOSTART_SESSION:-kibe-b1ec9}"

# Starship - prevent zle-keymap-select wrapping to avoid infinite recursion
export STARSHIP_NO_WRAP_KEYMAP=1

# pyenv - lazy loaded for performance
export PYENV_ROOT="$HOME/.pyenv"
[[ -d $PYENV_ROOT/bin ]] && export PATH="$PYENV_ROOT/bin:$PATH"
if command -v pyenv 1>/dev/null 2>&1; then
  eval "$(pyenv init - --no-rehash)"
fi
