alias hi="clear"

# cleanup ds_store files
alias cleanupds="find . -type f -name '*.DS_Store' -ls -delete"

# Count of non-hidden files in current dir
alias numfiles='echo $(ls | wc -l)'

alias kl='kill -9'

alias mkdir="mkdir -p"

# ls more organized
alias ls='ls --color -GFhla'

#tmux helpers
alias tmuxkw='tmux kill-window -t'
alias tmuxkp='tmux kill-pane -t'
alias tmuxks='tmux kill-session -t'

alias extract='unarchive'

# Short for docker
dk () {
  docker "$@"
}

dkcrun() {
  docker compose run "$@"
}

dce() {
  docker compose exec "$@"
}

dkc() {
  docker compose "$@"
}

alias dcup='docker compose up'
alias dcupd='docker compose up -d'

# get the current tmux layout
alias tmux_layout='tmux list-windows -F "#{window_active} #{window_layout}" | grep "^1" | cut -d " " -f 2'

# eza (modern ls replacement)
alias eza='eza --group-directories-first --icons'
alias ezo='eza --group-directories-first --icons --octal-permissions'
alias ezala='eza -la'
alias k='eza'
alias kla='ezala'

alias docker_stop_all='docker stop $(docker ps -a -q)'

if [ -x "$(command -v nvim)" ]; then
    alias vim=nvim
fi

# Reload zsh config with zgenom reset
alias reloadzsh='zgenom reset && source ~/.zshrc'

# Sync dotfiles with rcup
alias rcupd='rcup -d $HOME/Projects/me/dotfiles'
