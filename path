# Add `~/bin` to the `$PATH`
PATH=$HOME/.bin:$PATH
PATH=$HOME/bin:$PATH

# export npm packages installed in home dir to PATH
LOCAL_NPM_PACKAGES="${HOME}/.local/share/npm"
export PATH="$PATH:$LOCAL_NPM_PACKAGES/bin"

# include the above packages man files
# Preserve MANPATH if you already defined it somewhere in your config.
# Otherwise, fall back to `manpath` so we can inherit from `/etc/manpath`.
export MANPATH="${MANPATH-$(manpath)}:$LOCAL_NPM_PACKAGES/share/man"

# rbenv installation
PATH="$HOME/.rbenv/bin:$PATH"
if commandExists rbenv; then
  eval "$(rbenv init - --no-rehash)"
  PATH="$HOME/.rbenv/plugins/ruby-build/bin:$PATH"
fi

# coreutils (use brew prefix if available)
if commandExists brew; then
  _brew_prefix=$(brew --prefix)
  PATH="$_brew_prefix/opt/coreutils/libexec/gnubin:$PATH"
  MANPATH="$_brew_prefix/opt/coreutils/libexec/gnuman:$MANPATH"
  unset _brew_prefix
fi

# claude code
export PATH="$HOME/.local/bin:$PATH"
